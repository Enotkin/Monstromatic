<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:Monstromatic.Views;assembly=Monstromatic"
             xmlns:viewModels="clr-namespace:Monstromatic.ViewModels"
             mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="150"
             x:Class="Monstromatic.Views.MonsterView"
             x:DataType="viewModels:MonsterViewModel"
             Design.DataContext="{Binding Source={StaticResource DesignVmLocator}, Path=MonsterViewModel}">
    
    <UserControl.Styles>
        <StyleInclude Source="/Styles/HeaderStyles.axaml"></StyleInclude>
    </UserControl.Styles>

    <Border Name="Border" BorderThickness="2" BorderBrush="#FFA0A0A0" CornerRadius="5">
        <DockPanel LastChildFill="True">

            <Border DockPanel.Dock="Top" Background="#FFA0A0A0" CornerRadius="3,3,0,0" >
                <Grid VerticalAlignment="Top" RowDefinitions="*" ColumnDefinitions="*" Margin="0, 5">

                    <Border>
                        <Border.BorderThickness>2</Border.BorderThickness>
                        <Border.CornerRadius>10, 10, 0, 0</Border.CornerRadius>
                    </Border>

                    <Grid Grid.Row="0" Name="Header" ColumnDefinitions="Auto,*,Auto">
                        
                        <Grid.Styles>
                            <Style Selector="Button">
                                <Setter Property="VerticalAlignment" Value="Stretch"></Setter>
                                <Setter Property="HorizontalAlignment" Value="Stretch"></Setter>
                                <Setter Property="Margin" Value="3, 0"></Setter>
                            </Style>
                        </Grid.Styles>
                        
                        <!-- <Кнопка раскрытия окна> -->
                        <Button Name="HideButton" Grid.Column="0" Classes="round" Click="ChangeExpandState"
                                Margin="5, 0, 0, 0 "
                                Background="{StaticResource MonstromaticAccent}">
                            <Button.RenderTransform>
                                <RotateTransform Angle="0">
                                    <RotateTransform.Transitions>
                                        <Transitions>
                                            <DoubleTransition Property="Angle" Duration="0:0:0.1" Easing="SplineEasing"/>
                                        </Transitions>
                                    </RotateTransform.Transitions>
                                </RotateTransform>
                            </Button.RenderTransform>
                        
                            <Path Data="M 0 5 L 5 0 L 10 5" Stroke="{StaticResource ThemeControlHighlightLowBrush}"
                                  StrokeThickness="2">
                            </Path>
                        </Button>

                        <!-- Название монстра -->
                        <TextBlock Grid.Column="1" Text="{Binding Name}"
                                   Classes="main"
                                   HorizontalAlignment="Center"
                                   Margin="2, 2, 2, 5"
                                   TextWrapping="Wrap"/>
                        
                        
                        <!-- Кнопки управления -->
                        <Grid Grid.Column="2" Margin="0, 0, 0, 0 " ColumnDefinitions="*, *, *, *, *" HorizontalAlignment="Center" >
                            
                            <Button Grid.Column="0"  Command="{Binding RemoveLevel}" Content="&lt;&lt;" />
                            <TextBlock Grid.Column="1" Classes="main" Text="{Binding Level, StringFormat=Ур. \{0\}}" VerticalAlignment="Center"/>
                            <Button Grid.Column="2"  Command="{Binding AddLevel}" Content="&gt;&gt;" />
                            
                            <Button Grid.Column="3"  Command="{Binding ResetModificationsCommand}" Content="R" />

                            <!-- Закрыте окна -->
                            <Button Grid.Column="4"  Command="{Binding CloseCommand}" Background="#bb0000">
                                <Path Data="M 0 0 L 10 10 M 0 10 L 10 0"
                                      Stroke="{StaticResource ThemeControlHighlightLowBrush}" StrokeThickness="2">
                                </Path>
                            </Button>
                        </Grid>
                    
                    </Grid>
                </Grid>
            </Border>

            <ItemsControl Name="ExpanderGrid" ItemsSource="{Binding SkillsVm}">
                
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Columns="{Binding SkillsVm.Count}" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <views:SkillCounterView Margin="5, 0, 5, 5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
                
            </ItemsControl>
            
        </DockPanel>
    </Border>
</UserControl>